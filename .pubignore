**/.cxx/
**/.gradle/
**/local.properties
build/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub/
example/android/app/.cxx/
example/android/.gradle/
example/ios/.symlinks/
example/build/

# Platform build outputs
android/build/
ios/build/
linux/build/
macos/build/
windows/build/

# IDE files
.idea/
.vscode/
*.iml

# Development files
*.log
.dart_tool/

# Test coverage
coverage/

# Local notes
next-steps.txt

